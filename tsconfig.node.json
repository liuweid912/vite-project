{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "lib": ["ES2022"],
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false,
    "types": ["node"]
  },
  "include": ["vite.config.ts", "./*.config.js", "./*.config.ts"],
  "exclude": ["node_modules", "dist"]
}
