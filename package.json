{
  "name": "vite-vue-ts-template",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --mode dev",
    "build": "vue-tsc && vite build --mode prod",
    "build:analyze": "vue-tsc && vite build --mode prod --report",
    "preview": "vite preview",
    "lint": "eslint src/**/*.{vue,ts,js}",
    "lint:fix": "eslint src/**/*.{vue,ts,js} --fix",
    "format": "prettier --write src/**/*.{vue,ts,js,scss,json}",
    "format:check": "prettier --check src/**/*.{vue,ts,js,scss,json}",
    "prepare": "husky install"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "axios": "^1.7.7",
    "element-plus": "^2.14.2",
    "pinia": "^2.2.4",
    "vue": "^3.5.10",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@eslint/js": "^9.12.0",
    "@types/node": "^22.7.5",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-vue": "^5.1.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-vue": "^9.28.0",
    "globals": "^15.11.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "rollup-plugin-visualizer": "^5.12.0",
    "sass": "^1.79.4",
    "typescript": "^5.6.3",
    "unplugin-auto-import": "^0.18.3",
    "unplugin-vue-components": "^0.27.4",
    "vite": "^6.0.0",
    "vite-plugin-compression": "^0.5.1",
    "vue-tsc": "^2.1.6"
  },
  "lint-staged": {
    "*.{ts,vue,js}": [
      "eslint --fix --quiet",
      "prettier --write --quiet"
    ],
    "*.{scss,md,!(package).json}": [
      "prettier --write --quiet"
    ]
  }
}
